{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":URL:",
              ":NODE:",
              ["react", "react-dom", "react-dom/**"],
              ["next", "next/**"],
              [
                ":PACKAGE:",
                "!@rainbow-me/**",
                "!components/**",
                "!lib/**",
                "!css/**"
              ],
              "@rainbow-me/**",
              ":BLANK_LINE:",
              ["components/**", "lib/**", "css/**"],
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "files": {
    "includes": [
      "**",
      "!CHANGELOG.md",
      "!pnpm-lock.yaml",
      "!package.json",
      "!tsconfig.json",
      "!tsconfig.*.json",
      "!./packages/create-rainbowkit/generated-test-app",
      "!build",
      "!.react-router",
      "!examples/with-next-mint-nft/contract",
      "!packages/rainbowkit/assets/wallets/registry.json",
      "!**/next-env.d.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": false,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useButtonType": "off",
        "noLabelWithoutControl": "off",
        "noStaticElementInteractions": "off"
      },
      "complexity": {
        "noBannedTypes": "off",
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedVariables": "error"
      },
      "performance": {
        "noDelete": "off",
        "noImgElement": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useConsistentArrayType": "error"
      },
      "suspicious": {
        "noArrayIndexKey": "off",
        "noAssignInExpressions": "off",
        "noConfusingVoidType": "off",
        "noExplicitAny": "off",
        "noRedeclare": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  }
}
